{
  "name": "cynlang-vscode",
  "displayName": "CynLang",
  "description": "CynLang support (syntax, snippet, formatter)",
  "version": "0.0.1",
  "publisher": "cynthia",
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:cyn"],
  "contributes": {
    "languages": [
      {
        "id": "cyn",
        "aliases": ["CynLang", "cyn"],
        "extensions": [".cyn"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cyn",
        "scopeName": "source.cyn",
        "path": "./syntaxes/cyn.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cyn",
        "path": "./snippets/cyn.json"
      }
    ]
  },
  "main": "./formatter.js"
}
